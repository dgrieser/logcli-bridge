#!/bin/bash

APP_NAME="$(basename "${0}")"

usage() {
    cat <<EOF 1>&2
usage: ${APP_NAME} --host HOST [WRAPPER_OPTIONS] -- LOGCLI_ARGS...
       ${APP_NAME} --host HOST [WRAPPER_OPTIONS] LOGCLI_ARGS...
       ${APP_NAME} --kube [WRAPPER_OPTIONS] LOGCLI_ARGS...

Run logcli against Loki through Grafana's authenticated datasource proxy,
or directly against an in-cluster Loki via kubectl port-forward (--kube).

Wrapper options:
  -H, --host HOST         Grafana host or URL, for example grafana.example.com
  --datasource NAME       Grafana datasource name (default: Loki)
  --kube                  Connect to Loki via kubectl port-forward, bypassing Grafana
  --kube-namespace NS     Kubernetes namespace for Loki (default: monitoring)
  --kube-service NAME     Loki target: NAME, svc/NAME, or pod/NAME (default: loki)
  --kube-port PORT        Loki remote port to forward (default: 3100)
  --kube-context CTX      kubectl context override
                          In --kube mode the Grafana/auth options are ignored.

Authentication (pick one; default is OAuth login):
  (default)               Log in through OAuth
  --chrome-cookie-hijack  Authenticate with grafana_session cookies read from
                          Chrome's cookie store instead of OAuth
  --chrome-cookies PATH   Chrome Cookies sqlite DB path (for --chrome-cookie-hijack)
  --cookie COOKIE         Authenticate with an explicit Grafana Cookie header
                          value (also via LOGCLI_BRIDGE_COOKIE/GRAFANA_COOKIE)

OAuth options:
  --oauth-cache PATH      OAuth cache path (default: ~/.cache/logcli-bridge/session.json)
  --oauth-login-path PATH Grafana OAuth login path (default: /login/generic_oauth)
  --oauth-bearer-probe    Try localhost PKCE bearer auth before Grafana session auth
  --oauth-issuer URL      OAuth issuer override
  --oauth-client-id ID    OAuth client ID override
  --oauth-no-browser      Print OAuth URL instead of opening xdg-open
  --oauth-username NAME   Username for OAuth form fallback

Other options:
  --listen HOST           Local shim host (default: 127.0.0.1)
  --port PORT             Local shim port (default: random free port)
  --verbose               Print bridge target info and logcli request URLs
  -h, --help              Show this help message and exit

Environment:
  LOGCLI_BRIDGE_HOST            Same as --host
  LOGCLI_BRIDGE_DATASOURCE      Same as --datasource
  LOGCLI_BRIDGE_KUBE            Set to 1 to use kubectl port-forward (same as --kube)
  LOGCLI_BRIDGE_KUBE_NAMESPACE  Same as --kube-namespace
  LOGCLI_BRIDGE_KUBE_SERVICE    Same as --kube-service
  LOGCLI_BRIDGE_KUBE_PORT       Same as --kube-port
  LOGCLI_BRIDGE_KUBE_CONTEXT    Same as --kube-context
  LOGCLI_BRIDGE_CHROME_COOKIE_HIJACK  Set to 1 to use Chrome cookies (same as --chrome-cookie-hijack)
  LOGCLI_BRIDGE_OAUTH_CACHE     Same as --oauth-cache
  LOGCLI_BRIDGE_OAUTH_LOGIN_PATH Same as --oauth-login-path
  LOGCLI_BRIDGE_OAUTH_BEARER_PROBE  Same as --oauth-bearer-probe when set to 1
  LOGCLI_BRIDGE_OAUTH_ISSUER    Same as --oauth-issuer
  LOGCLI_BRIDGE_OAUTH_CLIENT_ID Same as --oauth-client-id
  LOGCLI_BRIDGE_OAUTH_NO_BROWSER  Same as --oauth-no-browser when set to 1
  LOGCLI_BRIDGE_OAUTH_USERNAME  Same as --oauth-username
  LOGCLI_BRIDGE_OAUTH_PASSWORD  Password for OAuth form fallback
  LOGCLI_BRIDGE_OAUTH_OTP       OTP for OAuth form fallback
  LOGCLI_BRIDGE_COOKIE          Same as --cookie
  LOGCLI_BRIDGE_CHROME_COOKIES  Same as --chrome-cookies

Examples:
  ${APP_NAME} --host grafana.example.com labels
  ${APP_NAME} -H grafana.example.com query --since=1h --limit=100 '{namespace="monitoring"}'
  ${APP_NAME} -H grafana.example.com query --tail '{namespace="monitoring"}'
  ${APP_NAME} --kube labels
  ${APP_NAME} --kube query --since=1h --limit=100 '{namespace="monitoring"}'
EOF
    exit 1
}

error() {
    echo "ERROR: ${1}" 1>&2
}

warning() {
    echo "WARNING: ${1}" 1>&2
}

fail() {
    error "${1}"
    exit 1
}

discover_grafana_host() {
    [ -z "${KUBECONFIG:-}" ] && return 1
    command -v kubectl >/dev/null 2>&1 || return 1

    kubectl get ingress -n monitoring kube-prometheus-grafana -o jsonpath='{.spec.rules[*].host}' 2>/dev/null
}

abort() {
    echo "Abort." 1>&2
    exit 1
}

run_kube_bridge() {
    command -v kubectl >/dev/null 2>&1 || fail "kubectl not found in PATH"

    local kube_target
    case "${kube_service}" in
        */*) kube_target="${kube_service}" ;;
        *)   kube_target="svc/${kube_service}" ;;
    esac

    local kube_cmd=(kubectl)
    [ -n "${kube_context}" ] && kube_cmd+=(--context "${kube_context}")
    kube_cmd+=(-n "${kube_namespace}")

    local address_arg=()
    if [ -n "${listen_host}" ] && [ "${listen_host}" != "127.0.0.1" ]; then
        address_arg+=(--address "${listen_host}")
    fi

    local spec
    if [ -z "${listen_port}" ] || [ "${listen_port}" = "0" ]; then
        spec=":${kube_remote_port}"
    else
        spec="${listen_port}:${kube_remote_port}"
    fi

    local pf_log
    pf_log="$(mktemp -t logcli-bridge-pf.XXXXXX)"

    if [ "${verbose}" = "1" ]; then
        echo "logcli-bridge: port-forward: ${kube_cmd[*]} port-forward ${kube_target} ${address_arg[*]} ${spec}" 1>&2
    fi
    "${kube_cmd[@]}" port-forward "${kube_target}" "${address_arg[@]}" "${spec}" >"${pf_log}" 2>&1 &
    local pf_pid=$!

    kube_cleanup() {
        kill "${pf_pid}" 2>/dev/null
        wait "${pf_pid}" 2>/dev/null
        rm -f "${pf_log}"
    }
    trap kube_cleanup EXIT INT TERM

    local local_port="" i
    for i in $(seq 1 100); do
        if ! kill -0 "${pf_pid}" 2>/dev/null; then
            error "kubectl port-forward exited before it was ready"
            cat "${pf_log}" 1>&2
            exit 1
        fi
        local_port="$(sed -n 's/^Forwarding from [^:]*:\([0-9][0-9]*\) ->.*/\1/p' "${pf_log}" | head -n1)"
        [ -n "${local_port}" ] && break
        sleep 0.1
    done
    if [ -z "${local_port}" ]; then
        error "timed out waiting for kubectl port-forward"
        cat "${pf_log}" 1>&2
        exit 1
    fi

    local bind_host="${listen_host:-127.0.0.1}"
    if [ "${verbose}" = "1" ]; then
        echo "logcli-bridge: kube target: ${kube_namespace}/${kube_target} (remote :${kube_remote_port})" 1>&2
        echo "logcli-bridge: local URL: http://${bind_host}:${local_port}" 1>&2
    fi

    local logcli_cmd=(logcli "--addr=http://${bind_host}:${local_port}")
    [ "${verbose}" != "1" ] && logcli_cmd+=(--quiet)
    logcli_cmd+=("${logcli_args[@]}")
    [ "${verbose}" = "1" ] && echo "logcli-bridge: running: ${logcli_cmd[*]}" 1>&2
    "${logcli_cmd[@]}"
    local rc=$?

    kube_cleanup
    trap - EXIT INT TERM
    exit "${rc}"
}

grafana_host_arg="${LOGCLI_BRIDGE_HOST:-}"
datasource="${LOGCLI_BRIDGE_DATASOURCE:-${GRAFANA_DATASOURCE:-Loki}}"
kube="${LOGCLI_BRIDGE_KUBE:-0}"
kube_namespace="${LOGCLI_BRIDGE_KUBE_NAMESPACE:-monitoring}"
kube_service="${LOGCLI_BRIDGE_KUBE_SERVICE:-loki}"
kube_remote_port="${LOGCLI_BRIDGE_KUBE_PORT:-3100}"
kube_context="${LOGCLI_BRIDGE_KUBE_CONTEXT:-}"
case "${kube}" in
    1|true|yes|on|TRUE|True|YES|ON) kube="1" ;;
    *) kube="0" ;;
esac
chrome_cookie_hijack="${LOGCLI_BRIDGE_CHROME_COOKIE_HIJACK:-0}"
case "${chrome_cookie_hijack}" in
    1|true|yes|on|TRUE|True|YES|ON) chrome_cookie_hijack="1" ;;
    *) chrome_cookie_hijack="0" ;;
esac
oauth_cache="${LOGCLI_BRIDGE_OAUTH_CACHE:-${XDG_CACHE_HOME:-${HOME}/.cache}/logcli-bridge/session.json}"
oauth_login_path="${LOGCLI_BRIDGE_OAUTH_LOGIN_PATH:-/login/generic_oauth}"
oauth_bearer_probe="${LOGCLI_BRIDGE_OAUTH_BEARER_PROBE:-0}"
oauth_issuer="${LOGCLI_BRIDGE_OAUTH_ISSUER:-}"
oauth_client_id="${LOGCLI_BRIDGE_OAUTH_CLIENT_ID:-}"
oauth_no_browser="${LOGCLI_BRIDGE_OAUTH_NO_BROWSER:-0}"
oauth_username="${LOGCLI_BRIDGE_OAUTH_USERNAME:-}"
oauth_password="${LOGCLI_BRIDGE_OAUTH_PASSWORD:-}"
oauth_otp="${LOGCLI_BRIDGE_OAUTH_OTP:-}"
chrome_cookies="${LOGCLI_BRIDGE_CHROME_COOKIES:-${CHROME_COOKIES:-${HOME}/.config/google-chrome/Default/Cookies}}"
cookie="${LOGCLI_BRIDGE_COOKIE:-${GRAFANA_COOKIE:-}}"
listen_host="127.0.0.1"
listen_port="0"
verbose="0"
logcli_args=()

while [ "${#}" -gt 0 ]; do
    case "${1}" in
        -h|--help)
            usage
            ;;
        -H|--host)
            shift
            [ -z "${1}" ] && usage
            grafana_host_arg="${1}"
            ;;
        --datasource)
            shift
            [ -z "${1}" ] && usage
            datasource="${1}"
            ;;
        --kube|--kube-proxy)
            kube="1"
            ;;
        --kube-namespace)
            shift
            [ -z "${1}" ] && usage
            kube_namespace="${1}"
            ;;
        --kube-service)
            shift
            [ -z "${1}" ] && usage
            kube_service="${1}"
            ;;
        --kube-port)
            shift
            [ -z "${1}" ] && usage
            kube_remote_port="${1}"
            ;;
        --kube-context)
            shift
            [ -z "${1}" ] && usage
            kube_context="${1}"
            ;;
        --chrome-cookie-hijack)
            chrome_cookie_hijack="1"
            ;;
        --oauth-cache)
            shift
            [ -z "${1}" ] && usage
            oauth_cache="${1}"
            ;;
        --oauth-login-path)
            shift
            [ -z "${1}" ] && usage
            oauth_login_path="${1}"
            ;;
        --oauth-bearer-probe)
            oauth_bearer_probe="1"
            ;;
        --oauth-issuer)
            shift
            [ -z "${1}" ] && usage
            oauth_issuer="${1}"
            ;;
        --oauth-client-id)
            shift
            [ -z "${1}" ] && usage
            oauth_client_id="${1}"
            ;;
        --oauth-no-browser)
            oauth_no_browser="1"
            ;;
        --oauth-username)
            shift
            [ -z "${1}" ] && usage
            oauth_username="${1}"
            ;;
        --chrome-cookies)
            shift
            [ -z "${1}" ] && usage
            chrome_cookies="${1}"
            ;;
        --cookie)
            shift
            [ -z "${1}" ] && usage
            cookie="${1}"
            ;;
        --listen)
            shift
            [ -z "${1}" ] && usage
            listen_host="${1}"
            ;;
        --port)
            shift
            [ -z "${1}" ] && usage
            listen_port="${1}"
            ;;
        --verbose)
            verbose="1"
            ;;
        --)
            shift
            [ -z "${grafana_host_arg}" ] && [ "${kube}" != "1" ] && usage
            logcli_args=("${@}")
            break
            ;;
        *)
            logcli_args=("${@}")
            break
            ;;
    esac
    shift
done

[ "${#logcli_args[@]}" -eq 0 ] && usage
command -v logcli >/dev/null 2>&1 || fail "logcli not found in PATH"

if [ "${kube}" = "1" ]; then
    run_kube_bridge
fi

if [ -z "${grafana_host_arg}" ]; then
    grafana_host_arg="$(discover_grafana_host)"
fi

[ -z "${grafana_host_arg}" ] && usage
command -v python3 >/dev/null 2>&1 || fail "python3 not found in PATH"

# Resolve the auth method explicitly: default OAuth, --chrome-cookie-hijack, or
# explicit cookie. They are mutually exclusive; no implicit fallback.
auth_method="oauth"
if [ "${chrome_cookie_hijack}" = "1" ]; then
    auth_method="chrome"
fi
if [ -n "${cookie}" ]; then
    if [ "${chrome_cookie_hijack}" = "1" ]; then
        fail "pick one auth method: --chrome-cookie-hijack and --cookie/LOGCLI_BRIDGE_COOKIE are mutually exclusive"
    fi
    auth_method="cookie"
fi

case "${grafana_host_arg}" in
    http://*|https://*)
        grafana_url="${grafana_host_arg}"
        ;;
    *)
        grafana_url="https://${grafana_host_arg}"
        ;;
esac

export LOGCLI_BRIDGE_GRAFANA_URL="${grafana_url}"
export LOGCLI_BRIDGE_DATASOURCE="${datasource}"
export LOGCLI_BRIDGE_AUTH_METHOD="${auth_method}"
export LOGCLI_BRIDGE_OAUTH_CACHE="${oauth_cache}"
export LOGCLI_BRIDGE_OAUTH_LOGIN_PATH="${oauth_login_path}"
export LOGCLI_BRIDGE_OAUTH_BEARER_PROBE="${oauth_bearer_probe}"
export LOGCLI_BRIDGE_OAUTH_ISSUER="${oauth_issuer}"
export LOGCLI_BRIDGE_OAUTH_CLIENT_ID="${oauth_client_id}"
export LOGCLI_BRIDGE_OAUTH_NO_BROWSER="${oauth_no_browser}"
export LOGCLI_BRIDGE_OAUTH_USERNAME="${oauth_username}"
export LOGCLI_BRIDGE_OAUTH_PASSWORD="${oauth_password}"
export LOGCLI_BRIDGE_OAUTH_OTP="${oauth_otp}"
export LOGCLI_BRIDGE_CHROME_COOKIES="${chrome_cookies}"
export LOGCLI_BRIDGE_COOKIE="${cookie}"
export LOGCLI_BRIDGE_LISTEN_HOST="${listen_host}"
export LOGCLI_BRIDGE_LISTEN_PORT="${listen_port}"
export LOGCLI_BRIDGE_VERBOSE="${verbose}"

if exec 3<&0; then
    export LOGCLI_BRIDGE_INPUT_FD="3"
else
