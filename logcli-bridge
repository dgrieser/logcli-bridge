        print(f"logcli-bridge: {message}", file=sys.stderr)


def safe_url(url):
    parsed = urlparse(str(url))
    return parsed._replace(query="", fragment="").geturl()


def origin_from_url(url):
    parsed = urlparse(url)
    return f"{parsed.scheme}://{parsed.netloc}"


def grafana_host(url):
    return urlparse(url).hostname or ""


def make_cookie_auth(cookie, source="cookie"):
    return {"type": "cookie", "cookie": cookie, "source": source}


def make_bearer_auth(token, source="oauth"):
    return {"type": "bearer", "token": token, "source": source}


def auth_headers(auth):
    if auth["type"] == "cookie":
        return {"Cookie": auth["cookie"]}
    if auth["type"] == "bearer":
        return {"Authorization": f"Bearer {auth['token']}"}
    raise UserError(f"unknown auth type: {auth.get('type')}")


def chrome_time_expired(expires_utc):
    if not expires_utc:
        return False
    # Chrome stores microseconds since 1601-01-01.
    unix_time = (int(expires_utc) / 1000000) - 11644473600
    return unix_time <= time.time()


def pkcs7_unpad(data):
    if not data:
        raise UserError("empty decrypted cookie")
    pad = data[-1]
    if pad < 1 or pad > 16 or data[-pad:] != bytes([pad]) * pad:
        raise UserError("invalid cookie padding")
    return data[:-pad]


def chrome_pbkdf2_key(password):
    password_bytes = password.encode("utf-8")
    kdf = PBKDF2HMAC(
        algorithm=SHA1(),
        length=16,
        salt=b"saltysalt",
        iterations=1,
    )
    return kdf.derive(password_bytes)


def decode_chrome_plain_cookie(plain, host):
    try:
        return plain.decode("utf-8")
    except UnicodeDecodeError:
        pass
    host_hash = hashlib.sha256(host.encode("utf-8")).digest()
    if plain.startswith(host_hash):
        return plain[32:].decode("utf-8")
    if len(plain) > 32:
        return plain[32:].decode("utf-8")
    raise UserError("cookie plaintext is not UTF-8")


def decrypt_linux_chrome_cookie(encrypted_value, passwords, host):
    if not encrypted_value:
        raise UserError("cookie encrypted_value missing")
    if encrypted_value.startswith(b"v10") or encrypted_value.startswith(b"v11"):
        body = encrypted_value[3:]
        # Old/current Linux Chrome format when no os_crypt encrypted_key exists:
        # AES-CBC with IV of 16 spaces and PBKDF2-derived key.
        for password in passwords:
            try:
                key = chrome_pbkdf2_key(password)
                cipher = Cipher(algorithms.AES(key), modes.CBC(b" " * 16))
                decryptor = cipher.decryptor()
                plain = decryptor.update(body) + decryptor.finalize()
                return decode_chrome_plain_cookie(pkcs7_unpad(plain), host)
            except Exception:
                pass
        # Newer AES-GCM cookies are v10/v11 + nonce + ciphertext + tag when
        # Local State exposes an encrypted_key. This profile does not, but keep
        # the branch for users with copied profiles.
        for password in passwords:
            try:
                key = chrome_pbkdf2_key(password)
                return decode_chrome_plain_cookie(AESGCM(key).decrypt(body[:12], body[12:], None), host)
            except Exception:
                pass
    raise UserError("could not decrypt Chrome cookie")


def secret_tool_passwords():
    candidates = []
    secret_tool = shutil.which("secret-tool")
    if not secret_tool:
        return candidates
    searches = [
        ["application", "chrome"],
        ["application", "chromium"],
        ["xdg:schema", "chrome_libsecret_os_crypt_password_v2"],
        ["xdg:schema", "chrome_libsecret_os_crypt_password_v1"],
    ]
    for attrs in searches:
        try:
            proc = subprocess.run(
                [secret_tool, "lookup", *attrs],
                check=False,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                timeout=3,
            )
        except Exception:
            continue
        value = proc.stdout.strip()
        if proc.returncode == 0 and value and value not in candidates:
            candidates.append(value)
    return candidates


def read_chrome_cookie_header():
    cookie_db = Path(CHROME_COOKIES).expanduser()
    if not cookie_db.exists():
        raise UserError(f"Chrome cookie DB not found: {cookie_db}")

    host = grafana_host(GRAFANA_URL)
    with tempfile.NamedTemporaryFile(prefix="logcli-bridge-cookies-", suffix=".sqlite") as tmp:
        shutil.copy2(cookie_db, tmp.name)
        con = sqlite3.connect(tmp.name)
        try:
            rows = con.execute(
                """
                select name, value, encrypted_value, expires_utc
                from cookies
                where host_key in (?, ?)
                  and name in ('grafana_session', 'grafana_session_expiry')
                """,
                (host, "." + host),
            ).fetchall()
        finally:
            con.close()

    if not rows:
        raise UserError(f"No Grafana cookies found for {host}; open {GRAFANA_URL} in Chrome and log in")

    passwords = secret_tool_passwords()
    for fallback in ("peanuts", ""):
        if fallback not in passwords:
            passwords.append(fallback)

    morsel_values = {}
    for name, value, encrypted_value, expires_utc in rows:
        if chrome_time_expired(expires_utc):
            continue
        if value:
            morsel_values[name] = value
            continue
        try:
            morsel_values[name] = decrypt_linux_chrome_cookie(encrypted_value, passwords, host)
        except UserError as exc:
            raise UserError(
                f"Could not decrypt {name}. Set GRAFANA_COOKIE manually after browser login."
            ) from exc

    if "grafana_session" not in morsel_values:
        raise UserError(f"No valid grafana_session cookie found for {host}; log in to {GRAFANA_URL}")

    return "; ".join(f"{name}={value}" for name, value in morsel_values.items())


def read_oauth_cache():
    path = Path(OAUTH_CACHE).expanduser()
    try:
        with path.open("r", encoding="utf-8") as fh:
            return json.load(fh)
    except FileNotFoundError:
        vprint(f"oauth: cache miss: {path}")
        return None
    except Exception as exc:
        vprint(f"oauth: ignoring unreadable cache {path}: {exc}")
        return None


def cached_oauth_auth():
    data = read_oauth_cache()
    if not data:
        return None
    if data.get("grafana_url") != GRAFANA_URL:
        vprint("oauth: ignoring cache for different Grafana URL")
        return None
    if OAUTH_ISSUER and data.get("issuer") != OAUTH_ISSUER:
        vprint("oauth: ignoring cache for different issuer")
        return None
    if OAUTH_CLIENT_ID and data.get("client_id") != OAUTH_CLIENT_ID:
        vprint("oauth: ignoring cache for different client ID")
        return None
    if int(data.get("expires_at") or 0) <= int(time.time()) + 60:
        vprint("oauth: ignoring expired cache")
        return None
    if data.get("type") == "bearer" and data.get("access_token"):
        vprint("oauth: using cached bearer token")
        return make_bearer_auth(data["access_token"], "oauth-cache")
    if data.get("type") == "cookie" and data.get("cookie"):
        vprint("oauth: using cached Grafana session cookie")
        return make_cookie_auth(data["cookie"], "oauth-cache")
    vprint("oauth: ignoring cache without supported auth material")
    return None


def save_oauth_cache(entry):
    path = Path(OAUTH_CACHE).expanduser()
    path.parent.mkdir(parents=True, exist_ok=True)
    entry = dict(entry)
    entry["grafana_url"] = GRAFANA_URL
    tmp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    fd = os.open(str(tmp), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as fh:
            json.dump(entry, fh, sort_keys=True)
            fh.write("\n")
        os.replace(tmp, path)
        os.chmod(path, stat.S_IRUSR | stat.S_IWUSR)
        vprint(f"oauth: saved {entry.get('type', 'unknown')} auth cache to {path}")
    finally:
        try:
            tmp.unlink()
        except FileNotFoundError:
            pass


def issuer_from_authorize_url(authorize_url):
    parsed = urlparse(authorize_url)
    marker = "/protocol/openid-connect/auth"
    if marker in parsed.path:
        issuer_path = parsed.path.split(marker, 1)[0]
        return f"{parsed.scheme}://{parsed.netloc}{issuer_path}".rstrip("/")
    return f"{parsed.scheme}://{parsed.netloc}".rstrip("/")


async def discover_oauth_config(session):
    authorize_url = ""
    client_id = OAUTH_CLIENT_ID
    issuer = OAUTH_ISSUER
    scope = "openid email profile offline_access roles"

    vprint(f"oauth: discovering config from Grafana {OAUTH_LOGIN_PATH}")
    try:
        async with session.get(f"{GRAFANA_URL}{OAUTH_LOGIN_PATH}", allow_redirects=False) as resp:
            location = resp.headers.get("Location", "")
            vprint(f"oauth: Grafana OAuth start returned HTTP {resp.status}")
            if 300 <= resp.status < 400 and location:
                authorize_url = urljoin(str(resp.url), location)
                vprint(f"oauth: Grafana redirects to {safe_url(authorize_url)}")
    except Exception:
        vprint("oauth: Grafana OAuth discovery request failed")
        authorize_url = ""

    if authorize_url:
        query = parse_qs(urlparse(authorize_url).query)
        if not client_id:
            client_id = (query.get("client_id") or [""])[0]
        scope = (query.get("scope") or [scope])[0]
        if not issuer:
            issuer = issuer_from_authorize_url(authorize_url)

    if not issuer:
        raise UserError("could not discover OAuth issuer; set --oauth-issuer")
    if not client_id:
        raise UserError("could not discover OAuth client ID; set --oauth-client-id")

    discovery_url = f"{issuer}/.well-known/openid-configuration"
    vprint(f"oauth: issuer={issuer} client_id={client_id} scope={scope!r}")
    vprint(f"oauth: loading OIDC discovery from {discovery_url}")
    try:
        async with session.get(discovery_url, allow_redirects=True) as resp:
            vprint(f"oauth: OIDC discovery returned HTTP {resp.status}")
            if resp.status < 400:
                data = await resp.json()
            else:
                data = {}
    except Exception as exc:
        vprint(f"oauth: OIDC discovery failed: {exc}")
        data = {}

    config = {
        "issuer": issuer,
        "client_id": client_id,
        "scope": scope,
        "authorization_endpoint": data.get(
            "authorization_endpoint",
            f"{issuer}/protocol/openid-connect/auth",
        ),
        "token_endpoint": data.get(
            "token_endpoint",
            f"{issuer}/protocol/openid-connect/token",
        ),
    }
    vprint(f"oauth: authorization endpoint {safe_url(config['authorization_endpoint'])}")
    vprint(f"oauth: token endpoint {safe_url(config['token_endpoint'])}")
    return config


def pkce_challenge(verifier):
    digest = hashlib.sha256(verifier.encode("ascii")).digest()
    return base64.urlsafe_b64encode(digest).rstrip(b"=").decode("ascii")


async def start_oauth_callback():
    loop = asyncio.get_running_loop()
    future = loop.create_future()

    async def handle_callback(request):
        if not future.done():
            future.set_result(dict(request.query))
        body = (
            "<!doctype html><html><head><title>logcli-bridge</title></head>"
            "<body>OAuth complete. You can close this window.</body></html>"
        )
        return web.Response(text=body, content_type="text/html")

    app = web.Application()
    app.router.add_route("*", "/{tail:.*}", handle_callback)
    runner = web.AppRunner(app, access_log=None)
    await runner.setup()
    site = web.TCPSite(runner, "127.0.0.1", 0)
    await site.start()
    sockets = list(site._server.sockets)
    if not sockets:
        await runner.cleanup()
        raise UserError("OAuth callback did not open a listening socket")
    port = sockets[0].getsockname()[1]
    vprint(f"oauth: localhost callback listening on 127.0.0.1:{port}")
    return runner, f"http://127.0.0.1:{port}/callback", future


def open_oauth_url(url):
    if not OAUTH_NO_BROWSER:
        opener = shutil.which("xdg-open")
        if opener:
            try:
                vprint(f"oauth: opening authorization URL with {opener}")
                subprocess.Popen(
                    [opener, url],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    start_new_session=True,
                )
                return
            except Exception:
                pass
    vprint("oauth: printing authorization URL for manual open")
    print(f"Open OAuth URL:\n{url}", file=sys.stderr)


async def browser_pkce_token(session, config):
    vprint("oauth: starting browser PKCE authorization")
    runner, redirect_uri, future = await start_oauth_callback()
    verifier = secrets.token_urlsafe(64)
    state = secrets.token_urlsafe(32)
    nonce = secrets.token_urlsafe(32)
    params = {
        "client_id": config["client_id"],
        "redirect_uri": redirect_uri,
        "response_type": "code",
        "scope": config["scope"],
        "state": state,
        "nonce": nonce,
        "code_challenge": pkce_challenge(verifier),
        "code_challenge_method": "S256",
    }
    authorize_url = f"{config['authorization_endpoint']}?{urlencode(params)}"

    try:
        open_oauth_url(authorize_url)
        vprint("oauth: waiting for localhost callback")
        query = await asyncio.wait_for(future, timeout=300)
    finally:
        await runner.cleanup()

    vprint(
        "oauth: callback received "
        f"code={'yes' if query.get('code') else 'no'} error={'yes' if query.get('error') else 'no'}"
    )
    if query.get("state") != state:
        raise UserError("OAuth callback state mismatch")
    if query.get("error"):
        detail = query.get("error_description") or query["error"]
        raise UserError(f"OAuth callback failed: {detail}")
    code = query.get("code")
    if not code:
        raise UserError("OAuth callback did not include a code")

    data = {
        "grant_type": "authorization_code",
        "client_id": config["client_id"],
        "code": code,
        "redirect_uri": redirect_uri,
        "code_verifier": verifier,
    }
    vprint("oauth: exchanging authorization code for tokens")
    async with session.post(config["token_endpoint"], data=data) as resp:
        text = await resp.text()
        vprint(f"oauth: token endpoint returned HTTP {resp.status}")
        if resp.status >= 400:
            if resp.status == 401 and (
                "unauthorized_client" in text or "Invalid client credentials" in text
            ):
                raise BearerUnavailable(
                    "OAuth client requires credentials; direct localhost token flow is unavailable"
                )
            raise UserError(f"OAuth token exchange failed ({resp.status}): {text[:300]}")
        token = json.loads(text)
    if not token.get("access_token"):
        raise UserError("OAuth token response did not include access_token")
    vprint(
        "oauth: token response received "
        f"access_token=yes refresh_token={'yes' if token.get('refresh_token') else 'no'}"
    )
    return token


async def grafana_accepts_bearer(session, auth):
    try:
        async with session.get(f"{GRAFANA_URL}/api/user", headers=auth_headers(auth)) as resp:
            vprint(f"oauth: Grafana bearer probe /api/user returned HTTP {resp.status}")
            if resp.status >= 400:
                await resp.read()
                return False
            data = await resp.json(content_type=None)
            accepted = isinstance(data, dict) and bool(data.get("id") or data.get("email") or data.get("login"))
            vprint(f"oauth: Grafana bearer probe accepted={'yes' if accepted else 'no'}")
            return accepted
    except Exception as exc:
        vprint(f"oauth: Grafana bearer probe failed: {exc}")
        return False


class FormParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.forms = []
        self.current = None

    def handle_starttag(self, tag, attrs):
        attrs = dict(attrs)
        if tag == "form":
            self.current = {
                "action": attrs.get("action", ""),
                "method": attrs.get("method", "get").lower(),
                "inputs": [],
            }
            self.forms.append(self.current)
        elif tag == "input" and self.current is not None:
            self.current["inputs"].append(attrs)

    def handle_endtag(self, tag):
        if tag == "form":
            self.current = None


def parse_forms(html):
    parser = FormParser()
    parser.feed(html)
    return parser.forms


def form_field_names(form):
    return {field.get("name", "") for field in form["inputs"] if field.get("name")}


def select_auth_form(forms):
    def score(form):
        names = form_field_names(form)
        if "password" in names and "username" in names:
            return 4
        if "password" in names:
            return 3
        if "otp" in names or "totp" in names:
            return 2
        if "username" in names:
            return 1
        return 0

    candidates = [(score(form), form) for form in forms]
    candidates = [item for item in candidates if item[0] > 0]
    if not candidates:
        return None
    candidates.sort(key=lambda item: item[0], reverse=True)
    return candidates[0][1]


def read_line_fd(fd):
    chunks = []
    while True:
        try:
            data = os.read(fd, 1)
        except OSError as exc:
            raise UserError("interactive OAuth prompt input failed") from exc
        if data == b"":
            raise UserError("interactive OAuth prompt input ended unexpectedly")
        if data == b"\n":
            break
        chunks.append(data)
    return b"".join(chunks).decode("utf-8", "replace").rstrip("\r")


def prompt_from_fd(fd, writer, prompt, secret=False):
    print(prompt, end="", file=writer, flush=True)
    old_attrs = None
    try:
        if secret and os.isatty(fd):
            old_attrs = termios.tcgetattr(fd)
            new_attrs = old_attrs[:]
            new_attrs[3] &= ~termios.ECHO
            termios.tcsetattr(fd, termios.TCSADRAIN, new_attrs)
        return read_line_fd(fd)
    finally:
        if old_attrs is not None:
            termios.tcsetattr(fd, termios.TCSADRAIN, old_attrs)
            print("", file=writer, flush=True)


def prompt_input(prompt, secret=False):
    try:
        with open("/dev/tty", "r+", encoding="utf-8") as tty:
            return prompt_from_fd(tty.fileno(), tty, prompt, secret)
    except OSError:
        pass

    if INPUT_FD:
        try:
            return prompt_from_fd(int(INPUT_FD), sys.stderr, prompt, secret)
        except (OSError, ValueError) as exc:
            raise UserError("interactive OAuth prompts require a terminal or readable stdin") from exc

    raise UserError("interactive OAuth prompts require a terminal or readable stdin")


def form_payload(form, username):
    payload = {}
    otp_fields = []
    has_password = False
    for field in form["inputs"]:
        name = field.get("name")
        if not name:
            continue
        field_type = field.get("type", "text").lower()
        if field_type in ("button", "file", "image", "reset"):
            continue
        if field_type in ("checkbox", "radio") and "checked" not in field and name != "rememberMe":
            continue
        payload[name] = field.get("value", "")
        if name == "username":
            if not username:
                username = prompt_input("OAuth username: ")
            payload[name] = username
        elif name == "password":
            has_password = True
        elif name in ("otp", "totp"):
            otp_fields.append(name)

    if has_password:
        vprint("oauth-form: password field found")
        payload["password"] = OAUTH_PASSWORD or prompt_input("OAuth password: ", secret=True)
    for name in otp_fields:
        vprint(f"oauth-form: OTP field found: {name}")
        payload[name] = OAUTH_OTP or prompt_input("OAuth OTP: ")
    return payload, username


def browserish_headers(url, method):
    headers = {
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "User-Agent": "Mozilla/5.0 logcli-bridge",
    }
    if method.upper() == "POST":
        headers["Origin"] = origin_from_url(url)
    return headers


def grafana_session_cookie_from_jar(session):
    cookies = session.cookie_jar.filter_cookies(URL(GRAFANA_URL))
    values = {}
    for name in ("grafana_session", "grafana_session_expiry"):
        if name in cookies:
            values[name] = cookies[name].value
    if "grafana_session" not in values:
        return None, None
    expires_at = int(time.time()) + 3600
    try:
        expires_at = int(values.get("grafana_session_expiry") or expires_at)
    except ValueError:
        pass
    header = "; ".join(f"{name}={value}" for name, value in values.items())
    return header, expires_at


async def grafana_session_form_auth():
    timeout = ClientTimeout(total=300, sock_connect=30)
    async with ClientSession(cookie_jar=CookieJar(unsafe=True), timeout=timeout) as session:
        url = f"{GRAFANA_URL}{OAUTH_LOGIN_PATH}"
        method = "GET"
        data = None
        username = OAUTH_USERNAME
        vprint("oauth-form: starting Grafana session login fallback")
        for step in range(1, 41):
            vprint(f"oauth-form: step {step}: {method} {safe_url(url)}")
            async with session.request(
                method,
                url,
                data=data,
                headers=browserish_headers(url, method),
                allow_redirects=False,
            ) as resp:
                text = await resp.text()
                vprint(f"oauth-form: step {step}: HTTP {resp.status} from {safe_url(resp.url)}")
                cookie, expires_at = grafana_session_cookie_from_jar(session)
                if cookie:
                    vprint(f"oauth-form: Grafana session cookie received; expires_at={expires_at}")
                    return make_cookie_auth(cookie, "oauth-form"), expires_at
                if 300 <= resp.status < 400:
                    location = resp.headers.get("Location")
                    if not location:
                        raise UserError(f"OAuth redirect from {resp.url} lacked Location")
                    url = urljoin(str(resp.url), location)
                    vprint(f"oauth-form: redirect to {safe_url(url)}")
                    method = "GET"
                    data = None
                    continue
                if resp.status >= 400:
                    raise UserError(f"OAuth form flow failed ({resp.status}): {text[:300]}")

                form = select_auth_form(parse_forms(text))
                if not form:
                    raise UserError(f"OAuth form flow reached unsupported page: {resp.url}")
                names = sorted(form_field_names(form))
                vprint(f"oauth-form: selected form fields: {', '.join(names)}")
                data, username = form_payload(form, username)
                url = urljoin(str(resp.url), form["action"] or str(resp.url))
                method = form["method"].upper()
                if method not in ("GET", "POST"):
                    method = "POST"
                vprint(f"oauth-form: submitting form via {method} {safe_url(url)}")
                if method == "GET":
                    url = f"{url}?{urlencode(data)}"
                    data = None
        raise UserError("OAuth form flow exceeded redirect limit")


async def oauth_auth():
    vprint("oauth: resolving OAuth auth")
    cached = cached_oauth_auth()
    if cached:
        return cached

    async with ClientSession(timeout=ClientTimeout(total=30)) as session:
        config = await discover_oauth_config(session)
        if OAUTH_BEARER_PROBE:
            try:
                token = await browser_pkce_token(session, config)
                auth = make_bearer_auth(token["access_token"], "oauth-bearer")
                if await grafana_accepts_bearer(session, auth):
                    expires_at = int(time.time()) + int(token.get("expires_in") or 3600)
                    save_oauth_cache(
                        {
                            "type": "bearer",
                            "issuer": config["issuer"],
                            "client_id": config["client_id"],
                            "access_token": token["access_token"],
                            "refresh_token": token.get("refresh_token", ""),
                            "expires_at": expires_at,
                        }
                    )
                    vprint(f"oauth: using bearer auth; expires_at={expires_at}")
                    return auth
                print("WARNING: Grafana rejected bearer token; falling back to Grafana session login", file=sys.stderr)
            except BearerUnavailable as exc:
                print(f"WARNING: {exc}; using Grafana session login", file=sys.stderr)
            except Exception as exc:
                print(f"WARNING: OAuth bearer flow failed; falling back to Grafana session login: {exc}", file=sys.stderr)
        else:
            vprint("oauth: skipping localhost bearer probe; using Grafana session login")

    auth, expires_at = await grafana_session_form_auth()
    save_oauth_cache(
        {
            "type": "cookie",
            "issuer": config["issuer"],
            "client_id": config["client_id"],
            "cookie": auth["cookie"],
            "expires_at": expires_at,
        }
    )
    vprint(f"oauth: using Grafana session auth; expires_at={expires_at}")
    return auth


async def resolve_auth():
    if AUTH_METHOD == "cookie":
        if not COOKIE:
            raise UserError("cookie auth selected but no cookie value set; pass --cookie or LOGCLI_BRIDGE_COOKIE")
        vprint("auth: using explicit cookie")
        return make_cookie_auth(COOKIE, "cookie")
    if AUTH_METHOD == "chrome":
        vprint("auth: using Chrome cookie hijack")
        return make_cookie_auth(read_chrome_cookie_header(), "chrome")
    if AUTH_METHOD == "oauth":
        return await oauth_auth()
    raise UserError(f"unknown auth method: {AUTH_METHOD!r}")


async def fetch_datasource_uid(session, auth):
    url = f"{GRAFANA_URL}/api/datasources/name/{quote(DATASOURCE, safe='')}"
    async with session.get(url, headers=auth_headers(auth)) as resp:
        text = await resp.text()
        if resp.status in (401, 403):
            raise UserError(f"Grafana rejected auth ({resp.status}); log in again")
        if resp.status >= 400:
            raise UserError(f"Grafana datasource lookup failed ({resp.status}): {text[:200]}")
        data = json.loads(text)
    uid = data.get("uid")
    if not uid:
        raise UserError(f"Grafana datasource {DATASOURCE!r} has no UID")
    return uid


def tail_query_from_logcli_args(args):
    if not args or args[0] != "query":
        return None
    tail = False
    query = None
    i = 1
    options_with_values = {
        "--output",
        "-o",
        "--timezone",
        "-z",
        "--output-timestamp-format",
        "--cpuprofile",
        "--memprofile",
        "--addr",
        "--username",
        "--password",
        "--ca-cert",
        "--cert",
        "--key",
        "--org-id",
        "--query-tags",
        "--bearer-token",
        "--bearer-token-file",
        "--retries",
        "--min-backoff",
        "--max-backoff",
        "--auth-header",
        "--proxy-url",
        "--limit",
        "--since",
        "--from",
        "--to",
        "--step",
        "--interval",
        "--batch",
        "--parallel-duration",
        "--parallel-max-workers",
        "--part-path-prefix",
        "--exclude-label",
        "--include-label",
        "--labels-length",
        "--store-config",
        "--schema-store",
        "--delay-for",
    }
    boolean_options = {
        "-q",
        "--quiet",
        "--stats",
        "--no-stats",
        "--stdin",
        "--no-stdin",
        "--tls-skip-verify",
        "--no-tls-skip-verify",
        "--nocache",
        "--no-nocache",
        "--compress",
        "--no-compress",
        "--envproxy",
        "--no-envproxy",
        "--overwrite-completed-parts",
        "--no-overwrite-completed-parts",
        "--merge-parts",
        "--no-merge-parts",
        "--keep-parts",
        "--no-keep-parts",
        "--forward",
        "--no-forward",
        "--no-labels",
        "--include-common-labels",
        "--no-include-common-labels",
        "--remote-schema",
        "--no-remote-schema",
        "--colored-output",
        "--no-colored-output",
        "--tail",
        "-t",
        "--follow",
        "-f",
    }
    while i < len(args):
        arg = args[i]
        if arg in ("--tail", "-t", "--follow", "-f"):
            tail = True
            i += 1
            continue
        if arg == "--":
            if i + 1 < len(args):
                query = args[i + 1]
            break
        if arg in options_with_values:
            i += 2
            continue
        if any(arg.startswith(prefix + "=") for prefix in options_with_values if prefix.startswith("--")):
            i += 1
            continue
        if arg in boolean_options:
            i += 1
            continue
        if arg.startswith("-"):
            i += 1
            continue
        query = arg
        i += 1
    if tail:
        return query
    return None


async def validate_tail_query(session, auth, uid, query):
    if not query:
        return
    now_ns = time.time_ns()
    params = urlencode(
        {
            "query": query,
            "limit": "1",
            "start": str(now_ns - 1_000_000_000),
            "end": str(now_ns),
        }
    )
    url = (
        f"{GRAFANA_URL}/api/datasources/proxy/uid/{quote(uid, safe='')}"
        f"/loki/api/v1/query_range?{params}"
    )
    async with session.get(url, headers=auth_headers(auth)) as resp:
        text = await resp.text()
        if resp.status < 400:
            return
        try:
            data = json.loads(text)
            message = data.get("error") or data.get("message") or text
        except Exception:
            message = text
        raise UserError(f"tail query validation failed ({resp.status}): {message.strip()[:500]}")


def copy_request_headers(request, auth):
    hop_by_hop = {
        "connection",
        "keep-alive",
        "proxy-authenticate",
        "proxy-authorization",
        "te",
        "trailer",
        "transfer-encoding",
        "upgrade",
        "host",
        "cookie",
        "authorization",
    }
    headers = {
        key: value
        for key, value in request.headers.items()
        if key.lower() not in hop_by_hop
    }
    headers.update(auth_headers(auth))
    headers["Origin"] = origin_from_url(GRAFANA_URL)
    return headers


def upstream_http_url(uid, request):
    path = request.path.lstrip("/")
    url = f"{GRAFANA_URL}/api/datasources/proxy/uid/{quote(uid, safe='')}/{path}"
    if request.query_string:
        url = f"{url}?{request.query_string}"
    return url


def upstream_ws_url(uid, request):
    parsed = urlparse(upstream_http_url(uid, request))
    scheme = "wss" if parsed.scheme == "https" else "ws"
    return parsed._replace(scheme=scheme).geturl()


async def handle_http(request):
    app = request.app
    auth = app["auth"]
    uid = app["uid"]
    session = app["session"]

    if request.headers.get("upgrade", "").lower() == "websocket":
        return await handle_ws(request)

    body = await request.read()
    headers = copy_request_headers(request, auth)
    async with session.request(
        request.method,
        upstream_http_url(uid, request),
        data=body,
        headers=headers,
        allow_redirects=False,
    ) as resp:
        excluded = {
            "connection",
            "keep-alive",
            "proxy-authenticate",
            "proxy-authorization",
            "te",
            "trailer",
            "transfer-encoding",
            "upgrade",
            "content-encoding",
        }
        response_headers = {
            key: value
            for key, value in resp.headers.items()
            if key.lower() not in excluded
        }
        data = await resp.read()
        return web.Response(status=resp.status, headers=response_headers, body=data)


async def pump_ws_to_upstream(local_ws, upstream_ws):
    async for msg in local_ws:
        if msg.type == WSMsgType.TEXT:
            await upstream_ws.send_str(msg.data)
        elif msg.type == WSMsgType.BINARY:
            await upstream_ws.send_bytes(msg.data)
        elif msg.type in (WSMsgType.CLOSE, WSMsgType.CLOSING, WSMsgType.CLOSED):
            await upstream_ws.close()
            break
        elif msg.type == WSMsgType.ERROR:
            await upstream_ws.close()
            break


async def pump_ws_to_local(upstream_ws, local_ws):
    async for msg in upstream_ws:
        if msg.type == WSMsgType.TEXT:
            await local_ws.send_str(msg.data)
        elif msg.type == WSMsgType.BINARY:
            await local_ws.send_bytes(msg.data)
        elif msg.type in (WSMsgType.CLOSE, WSMsgType.CLOSING, WSMsgType.CLOSED):
            await local_ws.close()
            break
        elif msg.type == WSMsgType.ERROR:
            await local_ws.close()
            break


async def handle_ws(request):
    app = request.app
    auth = app["auth"]
    uid = app["uid"]
    session = app["session"]

    local_ws = web.WebSocketResponse()
    await local_ws.prepare(request)

    headers = auth_headers(auth)
    headers["Origin"] = origin_from_url(GRAFANA_URL)
    try:
        async with session.ws_connect(upstream_ws_url(uid, request), headers=headers, heartbeat=30) as upstream_ws:
            tasks = [
                asyncio.create_task(pump_ws_to_upstream(local_ws, upstream_ws)),
                asyncio.create_task(pump_ws_to_local(upstream_ws, local_ws)),
            ]
            done, pending = await asyncio.wait(tasks, return_when=asyncio.FIRST_COMPLETED)
            for task in pending:
                task.cancel()
            for task in done:
                task.result()
    except Exception as exc:
        if not local_ws.closed:
            await local_ws.close(message=str(exc).encode("utf-8", "replace"))
    return local_ws


async def start_server(auth, uid):
    timeout = ClientTimeout(total=None, sock_connect=30)
    session = ClientSession(timeout=timeout)
    app = web.Application()
    app["auth"] = auth
    app["uid"] = uid
    app["session"] = session
    app.router.add_route("*", "/{tail:.*}", handle_http)

    runner = web.AppRunner(app, access_log=None)
    await runner.setup()
    site = web.TCPSite(runner, LISTEN_HOST, LISTEN_PORT)
    await site.start()
    sockets = list(site._server.sockets)
    if not sockets:
        raise UserError("local shim did not open a listening socket")
    port = sockets[0].getsockname()[1]
    return runner, session, port


async def run_logcli(port):
    cmd = ["logcli", f"--addr=http://{LISTEN_HOST}:{port}"]
    if not VERBOSE:
        cmd.append("--quiet")
    cmd.extend(LOGCLI_ARGS)
    vprint(f"running: {' '.join(shlex.quote(part) for part in cmd)}")
    proc = await asyncio.create_subprocess_exec(*cmd)
    try:
        return await proc.wait()
    except KeyboardInterrupt:
        proc.terminate()
        try:
            return await asyncio.wait_for(proc.wait(), timeout=5)
        except asyncio.TimeoutError:
            proc.kill()
            return await proc.wait()


async def main():
    try:
        auth = await resolve_auth()
        async with ClientSession(timeout=ClientTimeout(total=30)) as session:
            uid = await fetch_datasource_uid(session, auth)
            await validate_tail_query(session, auth, uid, tail_query_from_logcli_args(LOGCLI_ARGS))
        runner, session, port = await start_server(auth, uid)
        if VERBOSE:
            print(f"logcli-bridge: Grafana URL: {GRAFANA_URL}", file=sys.stderr)
            print(f"logcli-bridge: datasource {DATASOURCE!r} uid: {uid}", file=sys.stderr)
            print(f"logcli-bridge: auth source: {auth['source']} ({auth['type']})", file=sys.stderr)
            print(f"logcli-bridge: local URL: http://{LISTEN_HOST}:{port}", file=sys.stderr)
    except UserError as exc:
        fail(str(exc))
    except Exception as exc:
        fail(f"setup failed: {exc}")

    try:
        return await run_logcli(port)
    finally:
        await runner.cleanup()
        await session.close()


try:
    raise SystemExit(asyncio.run(main()))
except KeyboardInterrupt:
    raise SystemExit(130)
